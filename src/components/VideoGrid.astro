---
import { siteConfig } from '../config/clipx';
import type { VideoItem } from '../config/clipx';

interface Props {
  videos?: VideoItem[] | null;
  localization?: typeof siteConfig.branding.localization;
}

const videos = Astro.props.videos || siteConfig.placeholderData.videos;
const loc = Astro.props.localization || siteConfig.branding.localization;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-4 gap-y-8 xl:gap-x-6 xl:gap-y-10">
  {videos.map((video) => (
    <a href={`/watch?v=${video.id}`} class="group cursor-pointer block">
      {/* Thumbnail */}
      <div class="relative aspect-video rounded-2xl overflow-hidden bg-[#111111] transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_12px_30px_rgba(0,0,0,0.8)] border border-transparent group-hover:border-[#2a2a2a]">
        <img
          src={video.thumbnail}
          alt={video.title}
          class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500 ease-out"
          loading="lazy"
          decoding="async"
        />
        {/* Hover overlay */}
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
        {/* Duration badge */}
        {video.duration && (
          <div class:list={[
            'absolute bottom-2 right-2 px-1 py-0.5 rounded text-xs font-medium text-white',
            video.duration === 'LIVE'
              ? 'bg-red-600 uppercase tracking-wider text-[11px]'
              : 'bg-black/80',
          ]}>
            {video.duration === 'LIVE' ? '● LIVE' : video.duration}
          </div>
        )}
        {/* Hover progress bar preview */}
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-transparent group-hover:bg-[#f1f1f1]/20 transition-colors duration-300">
          <div class="h-full bg-[var(--primary-from)] w-0 group-hover:w-1/3 transition-all duration-1000 ease-out"></div>
        </div>
      </div>

      {/* Card Info */}
      <div class="flex gap-3 mt-3">
        {/* Avatar */}
        <div class="shrink-0 mt-0.5" onclick="event.stopPropagation()">
          <img
            src={video.author.avatar}
            alt={video.author.name}
            class="w-9 h-9 rounded-full object-cover hover:opacity-80 transition-opacity"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="min-w-0 flex-1">
          {/* Title */}
          <h3 class="text-[15px] font-bold text-[#f5f5f5] line-clamp-2 leading-tight group-hover:text-white transition-colors duration-200">
            {video.title}
          </h3>
          {/* Channel */}
          <div class="flex items-center gap-1 mt-1.5">
            <span class="text-[13px] font-medium text-[#a3a3a3] hover:text-[#f5f5f5] transition-colors truncate">
              {video.author.name}
            </span>
            {video.author.isVerified && (
              <svg class="w-3.5 h-3.5 text-[#aaa] shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            )}
          </div>
          {/* Views + Timestamp */}
          <div class="flex items-center text-[13px] font-medium text-[#777] mt-0.5">
            <span>{new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(video.views)} {loc.views}</span>
            <span class="mx-1.5">•</span>
            <span>{video.timestamp} {loc.ago}</span>
          </div>
        </div>

        {/* Three-dot menu (visible on hover) */}
        <button onclick="event.preventDefault(); event.stopPropagation();" class="self-start mt-0.5 w-8 h-8 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity rounded-full hover:bg-[#1a1a1a] cursor-pointer shrink-0">
          <svg class="w-5 h-5 text-[#f5f5f5]" fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="6" r="1.5" />
            <circle cx="12" cy="12" r="1.5" />
            <circle cx="12" cy="18" r="1.5" />
          </svg>
        </button>
      </div>
    </a>
  ))}
</div>
