---

<aside class="sidebar scrollbar-hide fixed top-16 left-0 right-0 h-14 bg-[#000000]/95 backdrop-blur-md border-b border-[#1f1f1f] z-40 flex items-center px-4 overflow-x-auto" aria-label="Top navigation">
  <div class="flex items-center h-full gap-4">
    {sidebarSections.map((section, sectionIdx) => (
      <div class="flex items-center h-full shrink-0">
        {sectionIdx > 0 && (
          <div class="w-px h-6 bg-[#333] mx-3"></div>
        )}
        <div class="flex items-center gap-2 h-full">
          {section.items.map((item) => (
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-2 px-4 h-9 rounded-full text-sm font-medium transition-colors whitespace-nowrap',
                item.active
                  ? 'bg-[#e50914] text-white shadow-sm font-bold'
                  : 'text-[#a3a3a3] hover:bg-[#1a1a1a] hover:text-white',
              ]}
            >
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={item.active ? "2" : "1.5"} set:html={iconPaths[item.icon] || ''} />
              <span>{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    {/* Footer links in Top Nav */}
    <div class="flex items-center h-full shrink-0">
      <div class="w-px h-6 bg-[#333] mx-3"></div>
      <div class="flex items-center gap-3">
        {footerLinks.slice(0, 3).map((link) => (
          <a href="#" class="text-[12px] text-[#666] hover:text-[#aaa] font-medium transition-colors whitespace-nowrap">{link}</a>
        ))}
        <span class="text-[12px] text-[#555] ml-2 whitespace-nowrap">{copyright}</span>
      </div>
    </div>
  </div>
</aside>
