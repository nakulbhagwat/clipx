---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabase';
import { siteConfig } from '../../config/clipx';

const supabase = supabaseServer(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();

if (!session) {
  return Astro.redirect('/login');
}

// Fetch user's channel info
const { data: profile } = await supabase
  .from('channels')
  .select('*')
  .eq('id', session.user.id)
  .single();

export const prerender = false;
---

<Layout title={`Studio - ${profile?.channel_name || 'Channel'}`} pageType="watch">
  <header class="sticky top-0 z-50 h-16 bg-[#000000]/80 backdrop-blur-xl flex items-center px-6 border-b border-[#1f1f1f]">
    <a href="/" class="flex items-center gap-1.5 select-none shrink-0 group" aria-label="ClipX Home">
      <svg class="w-10 h-10 transition-transform duration-300 group-hover:scale-110 drop-shadow-[0_0_12px_rgba(229,9,20,0.6)]" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10.5 8.35C10.5 5.86 13.2 4.3 15.36 5.54L28.12 12.89C30.28 14.13 30.28 17.25 28.12 18.49L15.36 25.84C13.2 27.08 10.5 25.52 10.5 23.03V8.35Z" stroke="url(#outerGradStudio)" stroke-width="2.5" stroke-linejoin="round"/>
        <path d="M15 12.35C15 10.86 16.62 9.93 17.91 10.67L25.57 15.09C26.86 15.83 26.86 17.71 25.57 18.45L17.91 22.87C16.62 23.61 15 22.68 15 21.19V12.35Z" fill="url(#innerGradStudio)"/>
        <defs>
          <linearGradient id="outerGradStudio" x1="10" y1="4" x2="29" y2="26" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#ffffff" />
            <stop offset="40%" stop-color="#e50914" />
            <stop offset="100%" stop-color="#3b0000" />
          </linearGradient>
          <linearGradient id="innerGradStudio" x1="15" y1="10" x2="26" y2="23" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#ff4d4d" />
            <stop offset="100%" stop-color="#b91c1c" />
          </linearGradient>
        </defs>
      </svg>
      <span class="font-black italic text-[30px] leading-none tracking-tight ml-0.5 flex items-baseline select-none">
        <span class="text-white drop-shadow-md">Clip</span><span class="text-[#e50914] drop-shadow-[0_0_8px_rgba(229,9,20,0.6)]">X</span>
      </span>
    </a>
    <div class="mx-4 h-6 w-px bg-[#333]"></div>
    <h1 class="text-lg font-bold text-[#f5f5f5]">Creator Studio</h1>
    <nav class="flex items-center gap-1 ml-6">
      <a href="/studio" class="px-4 py-1.5 rounded-full text-sm font-semibold bg-[#1f1f1f] text-[#f5f5f5]">Content</a>
      <a href="/studio/settings" class="px-4 py-1.5 rounded-full text-sm font-semibold text-[#888] hover:bg-[#1a1a1a] hover:text-[#f5f5f5] transition-colors">Customization</a>
    </nav>
    <div class="flex-1"></div>
    
    <div class="flex items-center gap-4">
      <a href="/" class="text-sm text-[#aaa] hover:text-[#f1f1f1] transition-colors">Exit Studio</a>
      <img src={profile?.avatar_url || 'https://api.dicebear.com/7.x/avataaars/svg?seed=fallback'} alt="Avatar" class="w-8 h-8 rounded-full border border-[#3d3d3d]" />
    </div>
  </header>

  <main class="max-w-[1400px] mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-[#f1f1f1]">Channel content</h2>
        <p class="text-[#aaa] text-sm mt-1">Manage your videos and shorts</p>
      </div>
      <a
        href="/studio/upload"
        class="flex items-center gap-2 px-5 py-2.5 bg-[#e50914] text-white rounded-full font-bold text-sm hover:bg-[#b91c1c] transition-all shadow-lg"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Upload Video
      </a>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="flex flex-col items-center justify-center py-20">
      <div class="w-10 h-10 border-2 border-white/20 border-t-white rounded-full animate-spin mb-4"></div>
      <p class="text-[#aaa] text-sm">Loading content...</p>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden flex-col items-center justify-center py-20 bg-[#0a0a0a] border border-[#1f1f1f] rounded-2xl">
      <div class="w-24 h-24 rounded-full bg-[#111111] flex items-center justify-center mb-6">
        <svg class="w-10 h-10 text-[#666]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </div>
      <p class="text-[#f5f5f5] font-bold text-lg mb-2">No content available</p>
      <p class="text-sm text-[#888] mb-6">Upload a video to get started sharing with your audience.</p>
      <a href="/studio/upload" class="px-5 py-2.5 bg-[#f5f5f5] text-black rounded-full font-bold text-sm hover:bg-white transition-colors">
        Upload Video
      </a>
    </div>

    <!-- Error State -->
    <div id="error-state" class="hidden bg-red-500/10 border border-red-500/20 rounded-xl p-4 mb-6">
      <p id="error-message" class="text-red-400 font-medium text-sm"></p>
    </div>

    <!-- Video Table -->
    <div id="video-table-wrapper" class="hidden overflow-x-auto rounded-2xl border border-[#1f1f1f] bg-[#0a0a0a]">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[#1f1f1f] text-[#888] text-xs uppercase tracking-wider bg-[#050505]">
            <th class="text-left p-4 font-bold rounded-tl-2xl">Video</th>
            <th class="text-left p-4 font-bold">Visibility</th>
            <th class="text-left p-4 font-bold">Date</th>
            <th class="text-left p-4 font-bold">Views</th>
            <th class="text-right p-4 font-bold rounded-tr-2xl">Actions</th>
          </tr>
        </thead>
        <tbody id="video-table-body" class="divide-y divide-[#1f1f1f]"></tbody>
      </table>
    </div>
  </main>

  <!-- Script to load user's videos -->
  <script>
    const loadingState = document.getElementById('loading-state')!;
    const emptyState = document.getElementById('empty-state')!;
    const errorState = document.getElementById('error-state')!;
    const errorMessage = document.getElementById('error-message')!;
    const tableWrapper = document.getElementById('video-table-wrapper')!;
    const tbody = document.getElementById('video-table-body')!;

    async function loadVideos() {
      try {
        const res = await fetch('/api/studio/videos');
        if (!res.ok) throw new Error('Failed to fetch videos');
        const videos = await res.json();

        loadingState.classList.add('hidden');

        if (videos.length === 0) {
          emptyState.classList.remove('hidden');
          emptyState.classList.add('flex');
          return;
        }

        tbody.innerHTML = videos.map((v: any) => `
          <tr class="hover:bg-[#272727]/50 transition-colors group">
            <td class="p-4">
              <div class="flex items-center gap-4">
                <div class="relative w-32 aspect-video bg-[#0f0f0f] rounded-lg overflow-hidden shrink-0 border border-[#272727]">
                  ${v.thumbnail_url 
                    ? `<img src="${v.thumbnail_url}" class="w-full h-full object-cover" />` 
                    : `<div class="flex items-center justify-center h-full text-xs text-[#666]">Processing</div>`
                  }
                  ${v.duration ? `<span class="absolute bottom-1 right-1 px-1 bg-black/80 text-[10px] font-medium text-white rounded">${v.duration}</span>` : ''}
                </div>
                <div class="min-w-0 flex-1">
                  <p class="font-medium text-[#f1f1f1] truncate">${v.title}</p>
                  <p class="text-xs text-[#aaa] truncate mt-1">${v.description || 'No description'}</p>
                </div>
              </div>
            </td>
            <td class="p-4 align-top pt-6">
              <div class="flex items-center gap-1.5 text-green-400">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span class="text-sm">Public</span>
              </div>
            </td>
            <td class="p-4 align-top pt-6">
              <p class="text-[#f1f1f1] text-sm">${new Date(v.created_at).toLocaleDateString()}</p>
              <p class="text-[#aaa] text-xs mt-0.5">Uploaded</p>
            </td>
            <td class="p-4 align-top pt-6">
              <p class="text-[#f1f1f1] text-sm">${v.view_count || 0}</p>
            </td>
            <td class="p-4 align-top pt-5 text-right">
              <a href="/watch?v=${v.id}" target="_blank" class="inline-flex items-center justify-center w-8 h-8 rounded-full hover:bg-[#3d3d3d] text-[#aaa] hover:text-[#f1f1f1] transition-colors" title="View on ClipX">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
              </a>
              <button onclick="deleteVideo('${v.id}')" class="inline-flex items-center justify-center w-8 h-8 rounded-full hover:bg-red-500/20 text-[#aaa] hover:text-red-400 transition-colors" title="Delete">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
              </button>
            </td>
          </tr>
        `).join('');
        tableWrapper.classList.remove('hidden');
      } catch (err: any) {
        loadingState.classList.add('hidden');
        errorState.classList.remove('hidden');
        errorMessage.textContent = err.message;
      }
    }

    (window as any).deleteVideo = async (id: string) => {
      if (!confirm('Are you sure you want to delete this video? This cannot be undone.')) return;
      try {
        const res = await fetch(`/api/studio/videos?id=${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error('Failed to delete video');
        loadVideos();
      } catch (err: any) {
        alert(err.message);
      }
    };

    loadVideos();
  </script>
</Layout>
