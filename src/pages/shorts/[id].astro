---
import Layout from '../../layouts/Layout.astro';
import { getVideoDetails, getTrendingShorts } from '../../lib/youtube';
import { loadSiteConfig } from '../../config/clipx';
import { isYouTubeUrl, getYouTubeId } from '../../utils/youtube';
import ShortsFeedItems from '../../components/ShortsFeedItems.astro';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/');
}

// Fetch the video from YouTube
const currentVideo = await getVideoDetails(id);

if (!currentVideo) {
  return Astro.redirect('/404');
}

// If they try to watch a standard video in the shorts player, redirect them
if (!currentVideo.isShort) {
  return Astro.redirect(`/watch?v=${id}`);
}

const trendingShorts = await getTrendingShorts('IN', 25);
const config = await loadSiteConfig();

// Create the feed list: requested video first, then the remaining trending shorts
const feedVideos = [
  currentVideo,
  ...trendingShorts.filter((v: any) => v.id !== id)
];

export const prerender = false;
---

<Layout 
  title={`${currentVideo.title} - ${config.branding.siteName} Shorts`}
  pageType="watch"
  theme={config.branding.theme}
>
  <main class="w-full h-screen bg-black text-white flex items-center justify-center relative overflow-hidden">
    
    <!-- Minimalist Back Button -->
    <a href="/" class="absolute top-6 left-6 z-50 w-12 h-12 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/60 backdrop-blur-md transition-colors border border-white/10 group">
      <svg class="w-6 h-6 text-white group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    </a>

    <!-- Scrollable Feed Container -->
    <div id="shorts-feed" class="relative z-10 w-full max-w-[450px] h-full sm:h-[calc(100vh-40px)] overflow-y-scroll snap-y snap-mandatory flex flex-col bg-black sm:rounded-[2rem] sm:border border-[#272727] shadow-2xl custom-scrollbar">
      <ShortsFeedItems videos={feedVideos} startIndex={0} />
    </div>
  </main>

  <style is:global>
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
      border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #444;
      border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #666;
    }
  </style>

  <script is:inline src="https://www.youtube.com/iframe_api"></script>
  <script is:inline>
    // CSS Scroll Snap Feed Logic with YouTube API
    let players = {};
    let isApiReady = false;
    let observer;
    let fetchingMore = false;
    let nextPageToken = null;
    let feedEndReached = false;

    window.onYouTubeIframeAPIReady = function() {
      isApiReady = true;
      initPlayers();
      setupObserver();
      setupClickListeners();
    };

    function initPlayers() {
      const iframes = document.querySelectorAll('.youtube-short:not([data-initialized="true"])');
      iframes.forEach((iframe) => {
        const index = iframe.getAttribute('data-index');
        iframe.setAttribute('data-initialized', 'true');
        players[index] = new YT.Player(iframe, {
           events: {
             'onReady': (event) => {
                // Autoplay the first video if it's currently visible
                if (index == 0) {
                   event.target.playVideo();
                }
             }
           }
        });
      });
    }

    function setupObserver() {
      const feed = document.getElementById('shorts-feed');
      
      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const container = entry.target;
          const iframe = container.querySelector('.youtube-short');
          
          if (entry.isIntersecting) {
            // Update the URL to the current video
            if (iframe) {
                const videoId = iframe.getAttribute('src').match(/embed\/([^?]+)/)?.[1];
                if (videoId) {
                    history.replaceState(null, '', `/shorts/${videoId}`);
                }
            }
            
            // Play video
            if (iframe) {
              const index = iframe.getAttribute('data-index');
              const player = players[index];
              if (player && typeof player.playVideo === 'function') {
                player.playVideo();
              }
            } else {
                const nativeVideo = container.querySelector('.native-short');
                if (nativeVideo) nativeVideo.play();
            }

            // Check if we need to load more
            const allContainers = Array.from(document.querySelectorAll('.short-container'));
            const currentIndex = allContainers.indexOf(container);
            
            if (!fetchingMore && !feedEndReached && currentIndex >= allContainers.length - 5) {
                fetchMoreShorts();
            }
          } else {
            // Pause video
            if (iframe) {
              const index = iframe.getAttribute('data-index');
              const player = players[index];
              if (player && typeof player.pauseVideo === 'function') {
                player.pauseVideo();
              }
            } else {
                const nativeVideo = container.querySelector('.native-short');
                if (nativeVideo) nativeVideo.pause();
            }
          }
        });
      }, { threshold: 0.6 });

      observeNewContainers();
    }

    function observeNewContainers() {
      const unobservedContainers = document.querySelectorAll('.short-container:not([data-observed="true"])');
      unobservedContainers.forEach(container => {
          container.setAttribute('data-observed', 'true');
          observer.observe(container);
      });
    }

    async function fetchMoreShorts() {
      fetchingMore = true;
      try {
        const feed = document.getElementById('shorts-feed');
        const currentIndexOffset = document.querySelectorAll('.short-container').length;
        
        const res = await fetch(`/api/shorts?pageToken=${nextPageToken || ''}&startIndex=${currentIndexOffset}`);
        if (!res.ok) throw new Error('Failed to fetch');
        
        const html = await res.text();
        
        if (html.trim()) {
           const tempDiv = document.createElement('div');
           tempDiv.innerHTML = html;
           
           const tokenContainer = tempDiv.querySelector('[data-next-page-token]');
           if (tokenContainer) {
             nextPageToken = tokenContainer.getAttribute('data-next-page-token');
             if (!nextPageToken) feedEndReached = true;
             
             // Append new children
             while (tokenContainer.firstChild) {
                feed.appendChild(tokenContainer.firstChild);
             }
             
             if (isApiReady) {
               initPlayers();
               setupClickListeners();
               observeNewContainers();
             }
           } else {
             feedEndReached = true;
           }
        } else {
           feedEndReached = true;
        }
      } catch (e) {
        console.error("Failed to fetch more shorts", e);
      }
      fetchingMore = false;
    }

    function setupClickListeners() {
      const overlays = document.querySelectorAll('[data-action="toggle-play"]:not([data-initialized="true"])');
      overlays.forEach(overlay => {
        overlay.setAttribute('data-initialized', 'true');
        overlay.addEventListener('click', () => {
          const index = overlay.getAttribute('data-index');
          const player = players[index];
          const indicator = overlay.parentElement.querySelector('.play-indicator');
          
          if (player && typeof player.getPlayerState === 'function') {
            const state = player.getPlayerState();
            if (state === 1) { // Playing
              player.pauseVideo();
              if(indicator) {
                 indicator.classList.remove('opacity-0');
              }
            } else { // Paused or Ended
              player.playVideo();
              if(indicator) {
                 indicator.classList.add('opacity-0');
              }
            }
          }
        });
      });
    }
  </script>
</Layout>
