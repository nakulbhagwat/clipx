---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/clipx';
import { supabaseServer } from '../lib/supabase';

// If user is already logged in, redirect them
const supabase = supabaseServer(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();

if (session) {
  return Astro.redirect('/');
}

// Ensure the page is SSR
export const prerender = false;
---

<Layout title={`Sign In - ${siteConfig.branding.siteName}`} pageType="watch">
  <Header branding={siteConfig.branding} />

  <main class="flex-1 flex items-center justify-center p-6 mt-14">
      <div class="w-full max-w-md bg-[#1a1a1a] rounded-3xl p-8 border border-[#272727] shadow-2xl relative overflow-hidden">
        {/* Decorative Glow */}
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-[var(--primary-from)]/20 rounded-full blur-[80px] pointer-events-none"></div>
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-[var(--primary-to)]/20 rounded-full blur-[80px] pointer-events-none"></div>

        <div class="relative z-10">
          <div class="text-center mb-8">
            <h1 class="text-3xl font-bold mb-2">Welcome Back</h1>
            <p class="text-[#aaa] text-sm">Sign in to {siteConfig.branding.siteName} to continue.</p>
          </div>

          <form id="login-form" class="space-y-5">
            <div>
              <label class="block text-xs font-medium text-[#aaa] uppercase tracking-wider mb-1.5">Email Address</label>
              <input type="email" id="email" required class="w-full px-4 py-3 bg-[#0f0f0f] border border-[#3d3d3d] rounded-xl text-[#f1f1f1] focus:outline-none focus:border-[var(--primary-from)] focus:ring-1 focus:ring-[var(--primary-from)] transition placeholder-[#666]" placeholder="you@example.com" />
            </div>

            <div>
              <label class="block text-xs font-medium text-[#aaa] uppercase tracking-wider mb-1.5">Password</label>
              <input type="password" id="password" required class="w-full px-4 py-3 bg-[#0f0f0f] border border-[#3d3d3d] rounded-xl text-[#f1f1f1] focus:outline-none focus:border-[var(--primary-from)] focus:ring-1 focus:ring-[var(--primary-from)] transition placeholder-[#666]" placeholder="••••••••" />
            </div>

            <div id="error-message" class="hidden p-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm"></div>

            <button type="submit" id="submit-btn" class="w-full py-3.5 bg-gradient-to-r from-[var(--primary-from)] to-[var(--primary-to)] text-white rounded-xl font-semibold hover:opacity-90 transition shadow-lg shadow-[var(--primary-from)]/25 flex justify-center items-center gap-2">
              <span>Sign In</span>
            </button>
          </form>

          <p class="text-center text-sm text-[#aaa] mt-8">
            Don't have an account? 
            <a href="/signup" class="text-[var(--primary-from)] hover:underline font-medium ml-1">Create one</a>
          </p>
        </div>
      </div>
    </main>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const errBox = document.getElementById('error-message') as HTMLDivElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        btn.disabled = true;
        btn.innerHTML = '<div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div> Signing in...';
        errBox.classList.add('hidden');

        try {
          const res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error || 'Failed to sign in. Check your credentials.');
          }

          // Redirect to home or studio on success
          window.location.href = '/';
        } catch (err: any) {
          errBox.textContent = err.message;
          errBox.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.innerHTML = '<span>Sign In</span>';
        }
      });
    </script>
</Layout>
